    "db:reset": "node scripts/db-reset.mjs",
    "mqtt:sim": "bash scripts/mqtt-simulator.sh",
    "mqtt:sim:normal": "bash scripts/mqtt-simulator.sh normal",
    "mqtt:sim:alert": "bash scripts/mqtt-simulator.sh alert",
    "mqtt:sim:chaos": "bash scripts/mqtt-simulator.sh chaos",
    "mqtt:sim:demo": "SIM_MAX_TICKS=30 bash scripts/mqtt-simulator.sh alert --interval 1"
  },
  "dependencies": {
    "next": "14.2.35",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.6.3"
  }
}
