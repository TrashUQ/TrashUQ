FROM public.ecr.aws/docker/library/node:20-alpine

WORKDIR /app

ARG BACKEND_API_URL=http://backend:4000
ARG NEXT_PUBLIC_MQTT_BROKER_URL=ws://localhost:9001/mqtt
ARG NEXT_PUBLIC_MQTT_TOPIC_ROOT=arduino
ARG NEXT_PUBLIC_MQTT_USERNAME=
ARG NEXT_PUBLIC_MQTT_PASSWORD=
ENV BACKEND_API_URL=${BACKEND_API_URL}
ENV NEXT_PUBLIC_MQTT_BROKER_URL=${NEXT_PUBLIC_MQTT_BROKER_URL}
ENV NEXT_PUBLIC_MQTT_TOPIC_ROOT=${NEXT_PUBLIC_MQTT_TOPIC_ROOT}
ENV NEXT_PUBLIC_MQTT_USERNAME=${NEXT_PUBLIC_MQTT_USERNAME}
ENV NEXT_PUBLIC_MQTT_PASSWORD=${NEXT_PUBLIC_MQTT_PASSWORD}

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

EXPOSE 3000

CMD ["npm", "run", "start", "--", "-p", "3000", "-H", "0.0.0.0"]
